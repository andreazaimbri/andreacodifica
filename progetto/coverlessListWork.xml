                            </monogr>
                            <series>
                                <title level="s" xml:lang="fr">Les Rougon-Macquart</title>
                                <biblScope unit="vol" n="8">vol. VIII</biblScope>
                            </series>
                            <note>Romanzo di intensa analisi psicologica, atipico nel ciclo per
                                l'assenza di critica sociale; pubblicato in feuilleton su
                                <title level="j" xml:lang="fr">Le Bien Public</title>.</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="Nana" type="romanzo">
