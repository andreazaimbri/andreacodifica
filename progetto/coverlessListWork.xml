                            </monogr>
                            <series>
                                <title level="s" xml:lang="fr">Les Rougon-Macquart</title>
                                <biblScope unit="vol" n="3">vol. III</biblScope>
                            </series>
                            <note>Ambientato alle Halles di Parigi; contrappone il mondo dei "grassi"
