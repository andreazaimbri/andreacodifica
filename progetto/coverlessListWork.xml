        <body xml:lang="it">
                    <listBibl xml:id="bibliografiaSecondaria">
                        
                        <!-- =========================
                             PERIODICI
                             ========================= -->
                        
                        <biblStruct xml:id="Farfalla" type="periodico">
                            <monogr>
                                <title level="j">La Farfalla</title>
                                <imprint>
                                    <pubPlace>Cagliari</pubPlace>
                                    <pubPlace>Milano</pubPlace>
                                    <!-- Editore non accertato dalle fonti disponibili -->
                                    <date from="1876" to="1883">1876-1883</date>
                                </imprint>
                            </monogr>
                            <note>Rivista letteraria e illustrata pubblicata tra Cagliari e Milano.</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="Gazzettino_rosa" type="periodico">
