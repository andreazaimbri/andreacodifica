                            </monogr>
                            <note>Quotidiano milanese di orientamento democratico e anticlericale,
                                diretto da Achille Bizzoni e Felice Cavallotti.</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="Sole" type="periodico">
                            <monogr>
                                <title level="j">Il Sole</title>
                                <imprint>
                                    <pubPlace>Milano</pubPlace>
                                    <publisher>Il Sole - F.lli Pennocchio e C.</publisher>
                                    <date from="1865" to="1965">1865-1965</date>
                                </imprint>
                            </monogr>
                            <note>Quotidiano economico italiano</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="Arte_drammatica" type="periodico">
                            <monogr>
                                <title level="j">Arte Drammatica</title>
                                <imprint>
                                    <pubPlace>Milano</pubPlace>
                                    <publisher>Cesare Beretta</publisher>
                                    <date from="1871" to="1934">1871-1934</date>
                                </imprint>
                            </monogr>
                            <note>Periodico teatrale milanese, tra le principali riviste specializzate
                                del teatro italiano nell'Ottocento.</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="Messager_de_l_Europe" type="periodico">
                            <monogr>
                                <title level="j" xml:lang="fr">Messager de l'Europe</title>
                                <imprint>
                                    <pubPlace>Pietroburgo</pubPlace>
                                    <publisher>M. Stasiulevič</publisher>
                                    <date from="1866" to="1918">1866-1918</date>
                                </imprint>
                            </monogr>
                            <note>Rivista letteraria russa di orientamento liberale e occidentalista,
                                che pubblicò corrispondenze e articoli di Zola sulla letteratura francese.</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="Bien_Public" type="periodico">
                            <monogr>
                                <title level="j" xml:lang="fr">Le Bien Public</title>
                                <imprint>
                                    <pubPlace>Dijon</pubPlace>
                                    <date from="1868" to="1944">1868-1944</date>
                                </imprint>
                            </monogr>
                            <note>Quotidiano francese di area regionale (Borgogna). Pubblicò in feuilleton
                                <title level="m" xml:lang="fr">Une page d'amour</title> di Zola (1877-1878).</note>
                        </biblStruct>
                        
                        <!-- 
                             OPERE ZOLA — ROMANZI PRECEDENTI AI ROUGON-MACQUART
                              -->
                        
