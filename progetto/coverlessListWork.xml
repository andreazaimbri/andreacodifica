                            </monogr>
                            <series>
                                <title level="s" xml:lang="fr">Les Rougon-Macquart</title>
                                <biblScope unit="vol" n="5">vol. V</biblScope>
                            </series>
                            <note>Storia di un giovane prete diviso tra fede e desiderio;
                                uno dei romanzi più lirici del ciclo.</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="Son_Excellence_Eugene_Rougon" type="romanzo">
                            <monogr>
                                <author ref="coverlessListPerson.xml#emileZola">Émile Zola</author>
