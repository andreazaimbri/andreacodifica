                            </monogr>
                            <series>
                                <title level="s" xml:lang="fr">Les Rougon-Macquart</title>
                                <biblScope unit="vol" n="4">vol. IV</biblScope>
                            </series>
                            <note>Ritratto della provincia sotto l'influenza del clero e della politica imperiale.</note>
                        </biblStruct>
                        
                        <biblStruct xml:id="La_Faute_de_l_abbe_Mouret" type="romanzo">
