                                    <pubPlace>Paris</pubPlace>
                                    <publisher>Lacroix et Verboeckhoven</publisher>
                                    <date when="1867">1867</date>
                                    <biblScope><idno type="wikidata">Q1125798</idno></biblScope>
                                </imprint>
                            </monogr>
                            <note>Romanzo naturalistico che anticipa i temi dei Rougon-Macquart;
