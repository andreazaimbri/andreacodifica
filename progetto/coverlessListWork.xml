                                    <publisher>Charpentier</publisher>
                                    <date when="1872">1872</date>
                                    <biblScope><idno type="wikidata">Q1386179</idno></biblScope>
                                </imprint>
                            </monogr>
                            <series>
                                <title level="s" xml:lang="fr">Les Rougon-Macquart</title>
                                <biblScope unit="vol" n="2">vol. II</biblScope>
                            </series>
