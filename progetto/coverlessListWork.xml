                            </monogr>
                            <note>Romanzo che esplora temi di ereditarietà e determinismo,
                                precursore della poetica naturalista dei Rougon-Macquart.</note>
                        </biblStruct>
                        
                        <!-- =========================
                             OPERE ZOLA — I ROUGON-MACQUART (ciclo completo, 20 romanzi)
                             ========================= -->
                        
