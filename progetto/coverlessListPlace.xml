<TEI xmlns="http://www.tei-c.org/ns/1.0">
    
    <teiHeader>
        <fileDesc>
            <titleStmt>
                <title>Lista dei luoghi citati</title>
            </titleStmt>
            
            <publicationStmt>
                <p>Progetto COVerLeSS</p>
            </publicationStmt>
            
            <sourceDesc>
                <p>Authority file dei luoghi</p>
            </sourceDesc>
        </fileDesc>
